# Email (Resend) — contact form
# https://resend.com — create API key; verify domain for production
RESEND_API_KEY=

# Where contact messages are delivered (optional; defaults in lib/inbox.ts)
CONTACT_NOTIFY_EMAIL=

# Optional; default is Resend test sender. Use e.g. Samayoga <noreply@yourdomain.com> after domain verify
RESEND_FROM_EMAIL=
