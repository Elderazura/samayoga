# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# NextAuth Configuration
AUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_URL=http://localhost:3000
# For production, update AUTH_URL to your actual domain

# Public registration form (Google Form, Typeform, etc.) — shown on /register
NEXT_PUBLIC_REGISTRATION_FORM_URL=
# Google Forms: enable “Get email notifications for new responses” in the form’s Responses tab.

# Email (Resend) — contact form + registration questionnaire notifications
# https://resend.com — create API key, verify sending domain (or use onboarding@resend.dev while testing)
RESEND_API_KEY=
# Where inbox messages are delivered (optional; defaults to Samayoga.yoga@gmail.com in code)
CONTACT_NOTIFY_EMAIL=Samayoga.yoga@gmail.com
# Optional; default is Resend’s test sender. Use e.g. Samayoga <noreply@yourdomain.com> after domain verify
RESEND_FROM_EMAIL=

# Google Gemini API (for AI features - optional)
GOOGLE_API_KEY=your_google_api_key_here
# Get your API key from: https://makersuite.google.com/app/apikey
